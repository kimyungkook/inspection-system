# =============================================================
# AI 주식 매매 가이드 앱 - 설정 파일
# =============================================================
# 사용 방법:
#   1. 이 파일을 복사해서 이름을 ".env" 로 바꾸세요
#   2. 아래 항목에서 "여기에입력" 부분만 실제 값으로 바꾸세요
#   3. 나머지는 건드리지 않아도 됩니다
# =============================================================


# -------------------------------------------------------
# [필수] 한국투자증권 API 키
# 발급 방법: 한국투자증권 앱 → KIS Developers → 앱 등록
# -------------------------------------------------------
KIS_APP_KEY=여기에입력
KIS_APP_SECRET=여기에입력
KIS_ACCOUNT_NUMBER=여기에입력        # 계좌번호 (예: 50123456-01)
KIS_IS_REAL=false                    # 실전: true / 모의투자: false


# -------------------------------------------------------
# [필수] AI 모델 설정
# LLM_PROVIDER 에 사용할 AI 이름 입력: claude / openai / gemini
# -------------------------------------------------------
LLM_PROVIDER=claude

# Claude (Anthropic) - console.anthropic.com 에서 발급
CLAUDE_API_KEY=여기에입력
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (교체 시 사용) - platform.openai.com 에서 발급
OPENAI_API_KEY=여기에입력
OPENAI_MODEL=gpt-4o

# Gemini (교체 시 사용) - aistudio.google.com 에서 발급
GEMINI_API_KEY=여기에입력
GEMINI_MODEL=gemini-1.5-pro


# -------------------------------------------------------
# [필수] 보안 키 (아무 문자나 길게 입력하세요 — 절대 외부 공개 금지)
# 예: MyStockApp_Super_Secret_Key_2024_!@#
# -------------------------------------------------------
JWT_SECRET_KEY=여기에_아무문자나_길게_입력하세요_32자_이상
AES_ENCRYPTION_KEY=여기에_32자리_아무문자나_입력하세요_!!


# -------------------------------------------------------
# [선택] 알림 설정
# -------------------------------------------------------

# 텔레그램 봇 (무료 — 먼저 설정 추천)
# 발급 방법: 텔레그램에서 @BotFather 검색 → /newbot 입력
TELEGRAM_BOT_TOKEN=여기에입력
TELEGRAM_CHAT_ID=여기에입력

# 카카오톡 알림톡 (나중에 설정)
KAKAO_API_KEY=여기에입력

# FCM 앱 푸시 알림 (나중에 설정)
FCM_SERVER_KEY=여기에입력


# -------------------------------------------------------
# 데이터베이스 설정 (기본값 그대로 사용해도 됩니다)
# -------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_NAME=stockapp
DB_USER=stockuser
DB_PASSWORD=stockpass123!


# -------------------------------------------------------
# 임시저장소 설정 (기본값 그대로 사용해도 됩니다)
# -------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass123!


# -------------------------------------------------------
# 앱 기본 설정
# -------------------------------------------------------
APP_ENV=development          # 개발중: development / 출시후: production
APP_PORT=8000
APP_SECRET=여기에_앱시크릿_입력
DEBUG=true

# JWT 토큰 만료 시간 설정
ACCESS_TOKEN_EXPIRE_MINUTES=15      # 로그인 토큰 유효시간 (15분)
REFRESH_TOKEN_EXPIRE_DAYS=7         # 자동 로그인 유지 기간 (7일)

# 초대코드 설정
INVITE_CODE_EXPIRE_HOURS=1          # 초대코드 유효시간 (1시간)
