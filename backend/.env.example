# =============================================================
# AI 주식 매매 가이드 앱 — 환경설정 파일 템플릿
#
# 사용 방법:
#   1. 이 파일을 복사해서 이름을 ".env" 로 변경하세요
#      (Windows: 파일 복사 후 이름 변경 → ".env" 입력)
#   2. 아래에서 "여기에 입력" 부분을 실제 값으로 채우세요
#   3. 저장 후 앱시작.bat 실행
# =============================================================


# ───────────────────────────────────────────
# [필수 1] 앱 기본 설정
# ───────────────────────────────────────────
APP_ENV=production
APP_PORT=8000
DEBUG=false


# ───────────────────────────────────────────
# [필수 2] 보안 키 — 아무 문자나 32자 이상 입력
# 예: 알파벳 + 숫자 + 특수문자를 섞어서 만드세요
# ───────────────────────────────────────────
JWT_SECRET_KEY=여기에_최소32자이상의_비밀키_입력_예시ABCabc123!@#
AES_ENCRYPTION_KEY=여기에_정확히32자의_암호화키_ABCabc1


# ───────────────────────────────────────────
# [필수 3] AI 모델 API 키
# LLM_PROVIDER: claude / openai / gemini 중 선택
# ───────────────────────────────────────────
LLM_PROVIDER=claude

# Claude (Anthropic) — console.anthropic.com 에서 발급
CLAUDE_API_KEY=여기에_Claude_API_키_입력
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI (선택사항)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini (선택사항)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro


# ───────────────────────────────────────────
# [필수 4] 한국투자증권 (KIS) API 키
# KIS Developers (apiportal.koreainvestment.com) 에서 발급
# ───────────────────────────────────────────
KIS_APP_KEY=여기에_KIS_앱키_입력
KIS_APP_SECRET=여기에_KIS_앱시크릿_입력
KIS_ACCOUNT_NUMBER=여기에_계좌번호_입력_예시01012345678901
KIS_IS_REAL=false
# KIS_IS_REAL=false → 모의투자 서버 (테스트용, 안전)
# KIS_IS_REAL=true  → 실전투자 서버 (실제 시세 데이터)


# ───────────────────────────────────────────
# [필수 5] 텔레그램 알림 설정
# 텔레그램 앱에서 @BotFather 검색 → /newbot 명령어로 봇 생성
# 채팅 ID: @userinfobot 에게 메시지 보내면 확인 가능
# ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=여기에_텔레그램_봇_토큰_입력_예시1234567890:ABC
TELEGRAM_CHAT_ID=여기에_텔레그램_채팅ID_입력_예시-1001234567890


# ───────────────────────────────────────────
# [선택] 카카오 알림톡 (나중에 추가 가능)
# ───────────────────────────────────────────
KAKAO_API_KEY=


# ───────────────────────────────────────────
# [자동] 데이터베이스 설정 — 변경 불필요
# Docker가 자동으로 설정합니다
# ───────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=stockapp
DB_USER=stockuser
DB_PASSWORD=stockpass_비밀번호_여기에입력


# ───────────────────────────────────────────
# [자동] Redis 설정 — 변경 불필요
# Docker가 자동으로 설정합니다
# ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_비밀번호_여기에입력


# ───────────────────────────────────────────
# [자동] 토큰 만료 시간 — 변경 불필요
# ───────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITE_CODE_EXPIRE_HOURS=1
