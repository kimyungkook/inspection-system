# =============================================================
# 데모 모드 환경설정 — API 키 없이 바로 실행 가능
# 실제 KIS API / Claude API 연결 없이 샘플 데이터로 동작합니다.
#
# 실행 방법: 데모시작.bat 더블클릭
#
# 데모 계정:
#   관리자 — 아이디: admin     비밀번호: demo1234!
#   일반    — 아이디: demo      비밀번호: demo1234!
# =============================================================

# 데모 모드 활성화 (이 값을 false로 바꾸면 실제 API 연결 모드)
DEMO_MODE=true

APP_ENV=development
APP_PORT=8000
DEBUG=true

# 보안 키 (데모용 고정값 — 실제 운영 시 반드시 변경)
JWT_SECRET_KEY=demo-jwt-secret-key-for-testing-only-do-not-use-in-production
AES_ENCRYPTION_KEY=demo-aes-key-32chars-testing!!

# AI 설정 (데모 모드에서는 실제 호출 안 함)
LLM_PROVIDER=claude
CLAUDE_API_KEY=demo-key-not-used-in-demo-mode
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
GEMINI_API_KEY=

# KIS API (데모 모드에서는 실제 호출 안 함)
KIS_APP_KEY=demo-key-not-used
KIS_APP_SECRET=demo-secret-not-used
KIS_ACCOUNT_NUMBER=demo-account
KIS_IS_REAL=false

# 텔레그램 (데모 모드에서는 알림 발송 안 함)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 데이터베이스
DB_HOST=db
DB_PORT=5432
DB_NAME=stockapp_demo
DB_USER=stockuser
DB_PASSWORD=demopass123!

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=demoredis123!

# 토큰 설정
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
INVITE_CODE_EXPIRE_HOURS=24
